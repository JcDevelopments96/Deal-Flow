# DealTrack environment variables
# Copy to .env.local for local dev. Set these in Vercel → Settings → Env Vars
# for production. See SAAS_PLAN.md for how to obtain each one.

# ───────────────────────────────────────────────────────────────────────
# CLIENT-SAFE (VITE_ prefix — bundled into the browser JS)
# ───────────────────────────────────────────────────────────────────────

# Clerk — authentication
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase — public URL + anon key (protected by Row-Level Security)
# https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe — publishable key (safe in client)
# https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs for each plan — created when you set up products in Stripe.
# Format: price_1Nxxxxxx
VITE_PRICING_STARTER_PRICE_ID=
VITE_PRICING_PRO_PRICE_ID=
VITE_PRICING_SCALE_PRICE_ID=

# Optional legacy — previous "bring your own key" flow.
# Leaving these set falls back to the old client-side RentCast/Zillow calls
# when SaaS mode is disabled. Safe to remove once SaaS goes live.
VITE_RENTCAST_API_KEY=
VITE_RAPIDAPI_ZILLOW_KEY=

# ───────────────────────────────────────────────────────────────────────
# SERVER-ONLY (no VITE_ prefix — never shipped to the browser)
# Set these only in Vercel env vars, not in .env.local that gets checked in.
# ───────────────────────────────────────────────────────────────────────

# Clerk — secret, verifies user JWTs in our API functions
CLERK_SECRET_KEY=

# Supabase — service role key (bypasses RLS for admin writes from the API)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — server
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# RentCast — DealTrack's master API key, paid plan
# Used for long-term rental comparables, and as a fallback for sale listings
# if the Realtor.com provider fails.
RENTCAST_API_KEY=

# Realtor.com via RapidAPI realty-in-us wrapper — primary source for sale
# listings (better photos). DealTrack fetches server-side; users never see
# this key. Sign up: https://rapidapi.com/apidojo/api/realty-in-us
RAPIDAPI_REALTOR_KEY=

# Zillow (via RapidAPI zillow-com1 wrapper) — master key
RAPIDAPI_ZILLOW_KEY=

# FRED (Federal Reserve Economic Data) — free, unlimited. Powers the live
# 30-year mortgage rate default in the Deal Analyzer.
# Get a key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# US Census Bureau — free, unlimited. Powers county-level demographics
# (population, median income, owner/renter ratio) shown on the market map.
# Get a key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# HUD (Department of Housing and Urban Development) — free, unlimited.
# Fair Market Rents per county (studio through 4BR). Shown alongside the
# Census data on county click.
# Get a token: https://www.huduser.gov/hudapi/public/register
HUD_API_TOKEN=

# ───────────────────────────────────────────────────────────────────────
# Feature flags
# ───────────────────────────────────────────────────────────────────────

# Set to "true" once auth + billing are configured. While false, the app
# behaves as the current single-user, bring-your-own-API-key tool.
VITE_SAAS_ENABLED=false
