# DealTrack environment variables
# Copy to .env.local for local dev. Set these in Vercel → Settings → Env Vars
# for production. See SAAS_PLAN.md for how to obtain each one.

# ───────────────────────────────────────────────────────────────────────
# CLIENT-SAFE (VITE_ prefix — bundled into the browser JS)
# ───────────────────────────────────────────────────────────────────────

# Clerk — authentication
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase — public URL + anon key (protected by Row-Level Security)
# https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe — publishable key (safe in client)
# https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs — one per plan × cadence. Create 6 recurring Prices in
# Stripe (3 plans × monthly + annual) and paste each price_1Nxxxxxx id below.
# If an annual id is missing, the upgrade modal disables the Annual toggle
# for that plan and keeps Monthly available.
#
# Suggested amounts (matches api/_lib/plans.js):
#   Starter monthly $29     | Starter annual $290
#   Pro monthly     $79     | Pro annual     $790
#   Scale monthly   $199    | Scale annual   $1990
VITE_PRICING_STARTER_PRICE_ID=
VITE_PRICING_STARTER_ANNUAL_PRICE_ID=
VITE_PRICING_PRO_PRICE_ID=
VITE_PRICING_PRO_ANNUAL_PRICE_ID=
VITE_PRICING_SCALE_PRICE_ID=
VITE_PRICING_SCALE_ANNUAL_PRICE_ID=

# Optional legacy — previous "bring your own key" flow.
# Leaving this set falls back to the old client-side Zillow calls
# when SaaS mode is disabled. Safe to remove once SaaS goes live.
VITE_RAPIDAPI_ZILLOW_KEY=

# ───────────────────────────────────────────────────────────────────────
# SERVER-ONLY (no VITE_ prefix — never shipped to the browser)
# Set these only in Vercel env vars, not in .env.local that gets checked in.
# ───────────────────────────────────────────────────────────────────────

# Clerk — secret, verifies user JWTs in our API functions
CLERK_SECRET_KEY=

# Supabase — service role key (bypasses RLS for admin writes from the API)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — server
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Realtor.com via RapidAPI realty-in-us wrapper — the one and only source
# for live sale listings. DealTrack fetches server-side; users never see
# this key. Rental data comes from free sources (HUD FMR + Zillow ZORI +
# Census), not a paid API — see CENSUS_API_KEY / HUD_API_TOKEN below.
# Sign up: https://rapidapi.com/apidojo/api/realty-in-us
RAPIDAPI_REALTOR_KEY=

# Zillow (via RapidAPI zillow-com1 wrapper) — master key
RAPIDAPI_ZILLOW_KEY=

# ───────────────────────────────────────────────────────────────────────
# Wholesaling feature (premium, paid tiers only)
# ───────────────────────────────────────────────────────────────────────

# ATTOM Data — property + owner records (absentee, years-owned, assessment).
# Pay-as-you-go, roughly $0.05/property. Sign up:
# https://api.developer.attomdata.com
ATTOM_API_KEY=

# Resend — transactional email for lead outreach. Free tier 3k/mo,
# then $0.0004/email. REQUIRED: verify your sending domain first.
# Sign up: https://resend.com
RESEND_API_KEY=
# Verified "From" address on Resend — e.g. hello@yourdomain.com
RESEND_FROM_EMAIL=

# BatchSkipTracing + Lob Postcards are BYOK — each user adds their own
# key in Wholesale → Integrations. You don't set a master key here.
#   - Skip-trace:  https://batchdata.com      (~$0.15 per lookup, user pays)
#   - Lob mail:    https://lob.com            (~$0.69 per postcard, user pays)

# Google Maps Platform — powers the Street View photo shown on every
# wholesale lead card. ~$0.007 per image view. You pay.
# Setup:
#   1. https://console.cloud.google.com/google/maps-apis/credentials
#   2. Create an API key, enable the "Street View Static API"
#   3. IMPORTANT: add an HTTP referrer restriction for your domain:
#        deal-flow-opal.vercel.app/*
#      Without this the key is scrape-able from the image URL.
GOOGLE_MAPS_API_KEY=

# Anthropic API — powers the "Ari" floating chat assistant.
# Get a key: https://console.anthropic.com → API Keys
# Costs ~$3 per million input tokens, ~$15 per million output tokens for
# Sonnet 4.6. Capped at 1024 output tokens per turn server-side.
ANTHROPIC_API_KEY=

# FRED (Federal Reserve Economic Data) — free, unlimited. Powers the live
# 30-year mortgage rate default in the Deal Analyzer.
# Get a key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# US Census Bureau — free, unlimited. Powers county-level demographics
# (population, median income, owner/renter ratio) shown on the market map.
# Get a key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# HUD (Department of Housing and Urban Development) — free, unlimited.
# Fair Market Rents per county (studio through 4BR). Shown alongside the
# Census data on county click.
# Get a token: https://www.huduser.gov/hudapi/public/register
HUD_API_TOKEN=

# BLS (Bureau of Labor Statistics) — free. OPTIONAL — without a key you get
# 25 requests per IP per day; with a key you get 500/day. Powers the live
# county unemployment rate shown in the market panel.
# Get a key: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Walk Score — free 5,000 calls/day with signup. Powers walk/bike/transit
# scores on listing detail. Without it, those fields silently hide.
# Sign up: https://www.walkscore.com/professional/api-sign-up.php
WALKSCORE_API_KEY=

# FEMA flood zones — no key required (uses public NFHL ArcGIS endpoint).
# Surfaces SFHA flood zone + insurance guidance on listing detail.

# ───────────────────────────────────────────────────────────────────────
# Feature flags
# ───────────────────────────────────────────────────────────────────────

# Set to "true" once auth + billing are configured. While false, the app
# behaves as the current single-user, bring-your-own-API-key tool.
VITE_SAAS_ENABLED=false
